# Edge Functions Configuration
EDGE_FUNCTIONS_BASE_URL=https://your-project.supabase.co/functions/v1
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# OAuth Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:3000/oauth/callback

MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:3000/oauth/callback

SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_REDIRECT_URI=http://localhost:3000/oauth/callback

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Edge Functions
EDGE_FUNCTIONS_ENABLED=true
EDGE_FUNCTIONS_TIMEOUT=30000
EDGE_FUNCTIONS_RETRY_ATTEMPTS=3
EDGE_FUNCTIONS_RETRY_DELAY=1000

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3001
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With,Content-Length,Accept,Origin

# Security
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Logging
LOG_LEVEL=info
LOG_FILE=logs/application.log
LOG_MAX_SIZE=10MB
LOG_MAX_FILES=5

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Cache Configuration
CACHE_TTL=3600  # 1 hour
CACHE_MAX_ITEMS=1000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ultron
DB_USER=postgres
DB_PASSWORD=your-db-password

# Redis (optional, for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@yourapp.com

# File Uploads
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf
UPLOAD_PATH=./uploads

# Security Headers
SECURE_HEADERS_ENABLED=true
CSP_ENABLED=true
HSTS_ENABLED=true
XSS_PROTECTION_ENABLED=true

# Monitoring
SENTRY_DSN=your-sentry-dsn-if-using-sentry
NEW_RELIC_LICENSE_KEY=your-new-relic-license-key

# Feature Flags
FEATURE_OAUTH_ENABLED=true
FEATURE_EDGE_FUNCTIONS_ENABLED=true
FEATURE_WEBHOOKS_ENABLED=true
FEATURE_API_KEYS_ENABLED=true

# Development
NODE_ENV=development
DEBUG=true
LOG_LEVEL=debug

# Production overrides (uncomment for production)
# NODE_ENV=production
# LOG_LEVEL=warn
# DEBUG=false