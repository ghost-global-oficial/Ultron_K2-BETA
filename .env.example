# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# ============================================================================
# OAUTH CREDENTIALS - Third-party Service Integrations
# ============================================================================

# Google Services (Gmail, Drive, Calendar)
# Console: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/oauth/callback"

# GitHub
# Console: https://github.com/settings/developers
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
GITHUB_REDIRECT_URI="http://localhost:3000/oauth/callback"

# Slack
# Console: https://api.slack.com/apps
SLACK_CLIENT_ID="your_slack_client_id"
SLACK_CLIENT_SECRET="your_slack_client_secret"
SLACK_SIGNING_SECRET="your_slack_signing_secret"
SLACK_REDIRECT_URI="http://localhost:3000/oauth/callback"

# Notion (Internal Integration)
# Console: https://www.notion.so/my-integrations
NOTION_INTEGRATION_SECRET="your_notion_integration_secret"

# Linear (use 127.0.0.1 instead of localhost)
# Console: https://linear.app/settings/api
LINEAR_CLIENT_ID="your_linear_client_id"
LINEAR_CLIENT_SECRET="your_linear_client_secret"
LINEAR_REDIRECT_URI="http://127.0.0.1:3000/oauth/callback"

# Asana
# Console: https://app.asana.com/0/developer-console
ASANA_CLIENT_ID="your_asana_client_id"
ASANA_CLIENT_SECRET="your_asana_client_secret"
ASANA_REDIRECT_URI="http://localhost:3000/oauth/callback"

# Stripe
# Console: https://dashboard.stripe.com/settings/applications
STRIPE_CLIENT_ID="your_stripe_client_id"
STRIPE_SECRET_KEY="your_stripe_secret_key"
STRIPE_REDIRECT_URI="http://localhost:3000/oauth/callback"

# Vercel (Personal Access Token)
# Console: https://vercel.com/account/tokens
VERCEL_TOKEN="your_vercel_token"

# Supabase (API Key)
# Console: https://app.supabase.com/project/_/settings/api
SUPABASE_URL="your_supabase_url"
SUPABASE_KEY="your_supabase_key"
