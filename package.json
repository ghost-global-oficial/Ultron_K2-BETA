{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "start": "start.bat",
    "dev": "tsx server.ts",
    "build": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json && node scripts/rename-electron.cjs",
    "electron:dev": "npm run build:electron && concurrently --kill-others \"npm run dev\" \"wait-on http://localhost:3000 && electron . --no-sandbox\"",
    "electron:build": "npm run build && npm run build:electron && electron-builder",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-electron",
    "lint": "tsc --noEmit",
    "test": "vitest --run",
    "init-credentials": "tsx scripts/init-credentials.ts",
    "security-audit": "tsx scripts/security-audit.ts",
    "migrate-to-supabase": "tsx scripts/migrate-to-supabase.ts",
    "test-supabase": "tsx scripts/test-supabase.ts",
    "test-supabase-simple": "tsx scripts/test-supabase-simple.ts",
    "test-supabase-final": "tsx scripts/test-supabase-final.ts",
    "check-supabase-data": "tsx scripts/check-supabase-data.ts",
    "setup-supabase": "tsx scripts/setup-supabase-direct.ts"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@supabase/supabase-js": "^2.47.10",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^12.8.0",
    "d3": "^7.9.0",
    "dompurify": "^3.3.2",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lit": "^3.3.2",
    "lucide": "^0.577.0",
    "marked": "^17.0.4",
    "motion": "^12.23.24",
    "node-fetch": "^3.3.2",
    "vite": "^6.2.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/marked": "^5.0.2",
    "@types/node": "^22.14.0",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "fast-check": "^4.6.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.ultron.aiagent",
    "productName": "ULTRON AI Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "server.ts",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "server.ts",
        "to": "server.js"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Development"
    }
  }
}
